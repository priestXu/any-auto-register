# Docker Compose ports
APP_PORT=8000
SOLVER_PUBLIC_PORT=8889

# Build/runtime proxy, leave empty if not needed
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1

# Solver runtime
APP_AUTO_START_SOLVER=1
APP_SOLVER_HEADLESS=1
APP_SOLVER_BROWSER_TYPE=camoufox

# Optional: explicitly point grok2api to a Python 3.13 interpreter
APP_GROK2API_PYTHON=
